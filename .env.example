HAPOALIM_USER_CODE=
HAPOALIM_PASSWORD=

# Cal credit cards. Add as many as you have (CAL_1_*, CAL_2_*, CAL_3_*, ...).
# OWNER is a label of your choice that tags every transaction from this login.
CAL_1_OWNER=
CAL_1_USERNAME=
CAL_1_PASSWORD=
CAL_2_OWNER=
CAL_2_USERNAME=
CAL_2_PASSWORD=

# WhatsApp via Kapso (https://app.kapso.ai). Use the proxy mode: API key + the
# phoneNumberId of the WhatsApp number you connected in the Kapso dashboard.
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
# Comma-separated ownerKey:displayName:number triples.
#   ownerKey    = ASCII, must match a CAL_n_OWNER above (used to find this person's Cal txns)
#   displayName = whatever should appear inside the WhatsApp message body (e.g. Hebrew)
#   number      = E.164 without '+'
# Example: Yuval:יובל:972544599580,Gal:גל:972544599581
WHATSAPP_RECIPIENTS=

# Pre-approved WhatsApp templates registered in the Kapso dashboard.
# Used by `npm run wa:summary`. The positive template fires when there's
# money left to spend this month; the negative one when over budget.
# Both templates take 4 positional params: {{1}} displayName, {{2}} last
# Cal txn amount, {{3}} last Cal txn place, {{4}} remaining magnitude.
WA_TEMPLATE_POSITIVE=
WA_TEMPLATE_NEGATIVE=
# Locale code as registered when the template was created in Kapso/Meta.
# This is the Meta locale key, NOT the content language — Kapso defaults to
# en_US even for Hebrew-content templates. Match exactly what shows in the
# Kapso dashboard "Language" column or sends will fail with #132001.
WA_TEMPLATE_LANG=en_US
